# Environment Configuration for SAT Vocabulary AI System

# Required: Hack Club AI API key
# Get your key from: https://ai.hackclub.com/dashboard
HACKCLUB_API_KEY=your_hackclub_api_key_here

# API Configuration
HACKCLUB_API_URL=https://ai.hackclub.com/proxy/v1
HACKCLUB_MODEL=google/gemini-2.5-flash

# Application Settings
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Data Storage (optional - uses default paths if not set)
DATA_DIR=data
FEEDBACK_DIR=feedback_data

# RAG Settings
RAG_SIMILARITY_THRESHOLD=0.1
QUALITY_SCORE_THRESHOLD=7.0
MAX_CONTEXT_EXAMPLES=3

# Security (set these in production)
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Performance Settings
CACHE_SIZE=100
MAX_WORKERS=4
